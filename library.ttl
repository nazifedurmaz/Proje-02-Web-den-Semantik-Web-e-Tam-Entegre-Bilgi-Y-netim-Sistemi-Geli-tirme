@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix dc:   <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema: <https://schema.org/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix lib:  <http://example.org/library#> .
@prefix libr: <http://example.org/library/resource/> .

# ============================================================
# ONTOLOGY DECLARATION
# ============================================================

lib:LibraryOntology a owl:Ontology ;
  rdfs:label "Kütüphane Ontolojisi"@tr ;
  rdfs:label "Library Ontology"@en ;
  rdfs:comment "Kütüphane yönetim sistemi için tasarlanmış semantik ontoloji."@tr ;
  owl:versionInfo "1.0" ;
  dcterms:created "2025-01-15"^^xsd:date ;
  dcterms:creator libr:author/A007 .

# ============================================================
# CLASS DEFINITIONS
# ============================================================

lib:Book a rdfs:Class, owl:Class ;
  rdfs:label "Kitap"@tr ;
  rdfs:label "Book"@en ;
  rdfs:comment "Kütüphanedeki bir kitabı temsil eden sınıf."@tr ;
  rdfs:subClassOf schema:Book .

lib:Author a rdfs:Class, owl:Class ;
  rdfs:label "Yazar"@tr ;
  rdfs:label "Author"@en ;
  rdfs:comment "Bir ya da daha fazla kitabın yazarını temsil eden sınıf."@tr ;
  rdfs:subClassOf schema:Person .

lib:Category a rdfs:Class, owl:Class ;
  rdfs:label "Kategori"@tr ;
  rdfs:label "Category"@en ;
  rdfs:comment "Kitapların sınıflandırıldığı kategoriyi temsil eden sınıf."@tr .

lib:Publisher a rdfs:Class, owl:Class ;
  rdfs:label "Yayınevi"@tr ;
  rdfs:label "Publisher"@en ;
  rdfs:subClassOf schema:Organization .

# ============================================================
# PROPERTY DEFINITIONS
# ============================================================

lib:hasAuthor a rdf:Property, owl:ObjectProperty ;
  rdfs:label "yazarı var"@tr ;
  rdfs:label "has author"@en ;
  rdfs:domain lib:Book ;
  rdfs:range lib:Author ;
  rdfs:subPropertyOf dc:creator .

lib:hasCategory a rdf:Property, owl:ObjectProperty ;
  rdfs:label "kategorisi var"@tr ;
  rdfs:label "has category"@en ;
  rdfs:domain lib:Book ;
  rdfs:range lib:Category .

lib:hasSubCategory a rdf:Property, owl:ObjectProperty ;
  rdfs:label "alt kategorisi var"@tr ;
  rdfs:label "has subcategory"@en ;
  rdfs:domain lib:Category ;
  rdfs:range lib:Category .

lib:isAvailable a rdf:Property, owl:DatatypeProperty ;
  rdfs:label "mevcut mu"@tr ;
  rdfs:label "is available"@en ;
  rdfs:domain lib:Book ;
  rdfs:range xsd:boolean .

lib:rating a rdf:Property, owl:DatatypeProperty ;
  rdfs:label "puanı"@tr ;
  rdfs:label "rating"@en ;
  rdfs:domain lib:Book ;
  rdfs:range xsd:decimal .

lib:isbn a rdf:Property, owl:DatatypeProperty ;
  rdfs:label "ISBN"@tr ;
  rdfs:label "ISBN"@en ;
  rdfs:domain lib:Book ;
  rdfs:range xsd:string .

lib:pageCount a rdf:Property, owl:DatatypeProperty ;
  rdfs:label "sayfa sayısı"@tr ;
  rdfs:label "page count"@en ;
  rdfs:domain lib:Book ;
  rdfs:range xsd:positiveInteger .

lib:nationality a rdf:Property, owl:DatatypeProperty ;
  rdfs:label "milliyeti"@tr ;
  rdfs:label "nationality"@en ;
  rdfs:domain lib:Author ;
  rdfs:range xsd:string .

lib:isActiveAuthor a rdf:Property, owl:DatatypeProperty ;
  rdfs:label "aktif yazar mı"@tr ;
  rdfs:label "is active author"@en ;
  rdfs:domain lib:Author ;
  rdfs:range xsd:boolean .

# ============================================================
# CATEGORY RESOURCES
# ============================================================

libr:category/C001 a lib:Category ;
  rdfs:label "Roman"@tr ;
  dc:description "Her türden uzun kurgusal anlatılar."@tr .

libr:category/C002 a lib:Category ;
  rdfs:label "Türk Edebiyatı"@tr ;
  dc:description "Türk yazarlara ait eserler."@tr ;
  lib:hasSubCategory libr:category/C001 .

libr:category/C003 a lib:Category ;
  rdfs:label "Distopya"@tr ;
  lib:hasSubCategory libr:category/C001 .

libr:category/C004 a lib:Category ;
  rdfs:label "Bilim Kurgu"@tr ;
  lib:hasSubCategory libr:category/C001 .

libr:category/C006 a lib:Category ;
  rdfs:label "Bilim ve Teknoloji"@tr .

libr:category/C007 a lib:Category ;
  rdfs:label "Tarih"@tr .

